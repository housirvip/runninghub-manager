# ==================================================
# RunningHub Manager 环境变量配置
# 复制此文件为 .env 后修改
# ==================================================

# ---- 服务器 ----
# 监听端口（含冒号）
PORT=:3060

# 本平台对外访问地址（用于生成文件下载链接等）
BASE_URL=http://localhost:3060

# ---- 数据库 ----
# 数据库驱动: sqlite (后期支持 mysql, postgres)
DB_DRIVER=sqlite

# SQLite 数据库文件路径
DB_PATH=./data/runninghub.db

# 数据库日志级别: silent / error / warn / info
DB_LOG_LEVEL=warn

# ---- 安全 ----
# JWT 签名密钥（必须设置！不设则每次重启后所有 token 失效）
JWT_SECRET=your-random-secret-at-least-32-chars

# 首次启动时创建的管理员密码（仅首次生效，不设则随机生成并打印到日志）
ADMIN_PASSWORD=

# 是否开放注册（true/false）
ALLOW_REGISTER=false

# ---- RunningHub ----
# RunningHub API 基础地址
RH_BASE_URL=https://www.runninghub.cn

# ---- 调度器 ----
# 调度策略: least-loaded（优先空闲）/ fill-first（优先填满）
SCHEDULE_STRATEGY=least-loaded

# 任务轮询间隔（秒），Worker 每隔此时间查询一次 RunningHub 任务状态
POLL_INTERVAL=3

# 最大轮询次数（超过后任务标记超时，默认 200 次 = 10分钟 @3s间隔）
POLL_MAX_ATTEMPTS=200

# ---- 文件存储 ----
# 上传文件存储目录
UPLOAD_DIR=./uploads

# 生成文件输出目录
OUTPUT_DIR=./output

# 上传文件大小限制（MB）
MAX_UPLOAD_SIZE_MB=50

# ---- 本地应用执行器 ----
# 本地自定义应用最大并发数
LOCAL_MAX_CONC=4
